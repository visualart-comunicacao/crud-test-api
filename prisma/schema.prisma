generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CAIXA
  GARCOM
  ATENDENTE
}

enum TableStatus {
  LIVRE
  OCUPADA
  RESERVADA
  INATIVA
}

enum OrderStatus {
  ABERTA
  FECHADA
  CANCELADA
}

enum OrderItemStatus {
  ATIVO
  CANCELADO
}

enum PaymentMethod {
  DINHEIRO
  PIX
  DEBITO
  CREDITO
  OUTRO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  CANCELADO
  ESTORNADO
}

enum CashRegisterStatus {
  ABERTO
  FECHADO
}

enum CashMovementType {
  VENDA
  DESPESA
  SANGRIA
  SUPRIMENTO
  ENTRADA
  AJUSTE
}

enum OrderOrigin {
  LOCAL
  DELIVERY
  RETIRADA
  BALCAO
}

enum DeliveryStatus {
  RECEBIDO
  PREPARANDO
  ROTA
  ENTREGUE
  CANCELADO
}

enum DriverStatus {
  DISPONIVEL
  EM_ROTA
  INATIVO
}

model User {
  id                 String   @id @default(cuid())
  name               String
  username           String   @unique
  password           String
  role               UserRole @default(ATENDENTE)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdOrders  Order[] @relation("OrderCreatedBy")
  closedOrders   Order[] @relation("OrderClosedBy")
  canceledOrders Order[] @relation("OrderCanceledBy")

  addedItems    OrderItem[] @relation("OrderItemAddedBy")
  canceledItems OrderItem[] @relation("OrderItemCanceledBy")

  openedCashRegisters CashRegister[] @relation("CashRegisterOpenedBy")
  closedCashRegisters CashRegister[] @relation("CashRegisterClosedBy")

  createdCashMovements CashMovement[] @relation("CashMovementCreatedBy")
  registeredPayments   Payment[]      @relation("PaymentRegisteredBy")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([name])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  imageUrl        String?
  prepTimeMinutes Int?
  isFeatured      Boolean @default(false)

  isActive      Boolean  @default(true)
  controlsStock Boolean  @default(false)
  stockCurrent  Decimal? @db.Decimal(10, 3)
  unit          String?
  printSector   String?

  availableInStore  Boolean @default(true)
  availableDelivery Boolean @default(true)
  availableCounter  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems  OrderItem[]
  additionals ProductAdditional[]
  comboItems  ComboItem[]
}

model RestaurantTable {
  id       String      @id @default(cuid())
  number   Int         @unique
  name     String?
  status   TableStatus @default(LIVRE)
  isActive Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  phone        String
  address      String?
  neighborhood String?
  reference    String?
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Driver {
  id        String       @id @default(cuid())
  name      String
  phone     String
  status    DriverStatus @default(DISPONIVEL)
  isActive  Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Order {
  id     String      @id @default(cuid())
  code   String      @unique
  status OrderStatus @default(ABERTA)

  // 🔥 DELIVERY
  origin         OrderOrigin?   @default(LOCAL)
  deliveryStatus DeliveryStatus @default(RECEBIDO)

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  customerName  String?
  customerPhone String?

  deliveryAddress      String?
  deliveryNeighborhood String?
  deliveryReference    String?
  deliveryChannel      String?

  priority         String? // normal | alta
  changeFor        Decimal? @db.Decimal(10,2)
  estimatedMinutes Int?

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  dispatchedAt DateTime?
  deliveredAt  DateTime?

  // RESTO DO SISTEMA
  tableId String?
  table   RestaurantTable? @relation(fields: [tableId], references: [id])

  notes String?

  subtotal       Decimal @default(0) @db.Decimal(10, 2)
  serviceFee     Decimal @default(0) @db.Decimal(10, 2)
  couvertTotal   Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @default(0) @db.Decimal(10, 2)

  createdById String
  createdBy   User @relation("OrderCreatedBy", fields: [createdById], references: [id])

  closedById String?
  closedBy   User? @relation("OrderClosedBy", fields: [closedById], references: [id])

  canceledById String?
  canceledBy   User? @relation("OrderCanceledBy", fields: [canceledById], references: [id])

  openedAt   DateTime @default(now())
  closedAt   DateTime?
  canceledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        OrderItem[]
  payments     Payment[]
  CashMovement CashMovement[]

  @@index([origin])
  @@index([deliveryStatus])
  @@index([customerId])
  @@index([driverId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)

  notes String?

  status OrderItemStatus @default(ATIVO)

  addedById String
  addedBy   User @relation("OrderItemAddedBy", fields: [addedById], references: [id])

  canceledById String?
  canceledBy   User? @relation("OrderItemCanceledBy", fields: [canceledById], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  canceledAt DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method PaymentMethod
  status PaymentStatus @default(PENDENTE)
  amount Decimal @db.Decimal(10, 2)
  paidAt DateTime?

  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  registeredById String
  registeredBy   User @relation("PaymentRegisteredBy", fields: [registeredById], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CashRegister {
  id     String @id @default(cuid())
  status CashRegisterStatus @default(ABERTO)

  openedById String
  openedBy   User @relation("CashRegisterOpenedBy", fields: [openedById], references: [id])

  closedById String?
  closedBy   User? @relation("CashRegisterClosedBy", fields: [closedById], references: [id])

  openingAmount    Decimal @db.Decimal(10, 2)
  expectedAmount   Decimal @default(0) @db.Decimal(10, 2)
  informedAmount   Decimal? @db.Decimal(10, 2)
  differenceAmount Decimal? @db.Decimal(10, 2)
  openingNotes String?
  closingNotes String?
  observations String?

  openedAt DateTime @default(now())
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements CashMovement[]
  payments  Payment[]
}

model CashMovement {
  id String @id @default(cuid())

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  type   CashMovementType
  amount Decimal @db.Decimal(10, 2)

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id])

  createdById String
  createdBy   User @relation("CashMovementCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Additional {
  id       String  @id @default(cuid())
  name     String
  price    Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductAdditional[]

  @@unique([name])
}

model ProductAdditional {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  additionalId String
  additional   Additional @relation(fields: [additionalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, additionalId])
}

model Combo {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ComboItem[]
}

model ComboItem {
  id String @id @default(cuid())

  comboId String
  combo   Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([comboId, productId])
}

model Setting {
  id Int @id @default(autoincrement())

  razaoSocial                String?
  nomeFantasia               String?
  cnpj                       String?
  telefone                   String?
  whatsapp                   String?
  email                      String?
  endereco                   String?
  numero                     String?
  bairro                     String?
  cidade                     String?
  uf                         String?
  cep                        String?
  horarioFuncionamento       String?
  taxaServico                Float?
  couvert                    Float?
  rodapeCupom                String?
  logoUrl                    String?

  usaMesa                    Boolean  @default(true)
  usaComanda                 Boolean  @default(true)
  comandaObrigatoria         Boolean  @default(false)
  qtdMesas                   Int?
  separarPedidoPorSetor      Boolean  @default(true)
  bloquearVendaSemEstoque    Boolean  @default(true)
  exigirObservacaoCancelamento Boolean @default(true)
  permitirDescontoLivre      Boolean  @default(false)

  impressoraCozinha          String?
  impressoraBar              String?
  impressoraCaixa            String?
  tamanhoPapel               String?
  imprimirAutomaticamente    Boolean  @default(true)
  imprimirDuasVias           Boolean  @default(false)
  imprimirNomeGarcom         Boolean  @default(true)
  imprimirHorario            Boolean  @default(true)

  somNovoPedido              Boolean  @default(true)
  alertaPedidoPronto         Boolean  @default(true)
  alertaMesaAbertaSemConsumo Boolean  @default(false)
  tempoAlertaMesaSemConsumo  Int?

  tema                       String?
  formatoData                String?
  fusoHorario                String?
  logoutAutomaticoMinutos    Int?
  forcarTrocaSenhaPadrao     Boolean  @default(true)
  exibirAtalhosInicio        Boolean  @default(true)

  whatsappToken              String?
  webhookPedidos             String?
  ifoodHabilitado            Boolean  @default(false)
  apiEntregaHabilitada       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}